# Streamlit Secrets - 設定例
# このファイルをコピーして secrets.toml として使用してください

# AWS認証情報（Bedrock使用）
# ローカル開発: AWS CLIの認証情報を使用（~/.aws/credentials）
# 本番環境: Streamlit Community Cloud の Secrets 設定で管理

[aws]
# AWSリージョン（Bedrockが利用可能なリージョンを指定）
region = "us-east-1"

# 使用するClaudeモデルID
# ※ Cross-Region Inference Profile (従量課金プラン用) - 先頭に us. が必要
model_id = "us.anthropic.claude-3-5-sonnet-20241022-v2:0"

# 本番デプロイ時は、Streamlit Community Cloudのダッシュボードで以下を設定:
# AWS_ACCESS_KEY_ID = "your-access-key"
# AWS_SECRET_ACCESS_KEY = "your-secret-key"
# AWS_DEFAULT_REGION = "us-east-1"
